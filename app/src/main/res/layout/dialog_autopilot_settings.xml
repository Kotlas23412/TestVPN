<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Макс. серверов для экспорта">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/ap_limit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:text="10" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- ВОТ ЭТО НОВОЕ ПОЛЕ ДЛЯ ТИХОЙ ПРОВЕРКИ -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Тихая проверка серверов каждые (мин)">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/ap_health_interval"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:text="10" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Макс. допустимый пинг (мс)">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/ap_max_ping"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:text="3000" />
        </com.google.android.material.textfield.TextInputLayout>

        <CheckBox
            android:id="@+id/ap_combine"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Объединить все группы в один экспорт"
            android:checked="true" />

        <CheckBox
            android:id="@+id/ap_strict_whitelist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="🛡 Режим Шатдауна (Искать только прокси с 'белыми' SNI: RU-банки, ВК, Yandex)" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="ℹ️ Алгоритм:\nСистема будет незаметно проверять серверы с заданным интервалом. Если серверы умрут, Автопилот сам скачает новые, отберет лучшие и обновит GitHub."
            android:textColor="#FF9800"
            android:textSize="13sp" />

    </LinearLayout>
</ScrollView>